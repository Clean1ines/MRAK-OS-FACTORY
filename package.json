{
  "name": "mrak-os-factory-root",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"BACK,FRONT\" -c \"magenta,cyan\" \"uvicorn server:app --reload --port 8000\" \"npm run dev --prefix frontend\"",
    "install:all": "npm install && npm install --prefix frontend",
    "test:e2e": "npm run test:e2e --prefix frontend",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "playwright:install": "npm run playwright:install --prefix frontend"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^8.2.2"
  }
}
